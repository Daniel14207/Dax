rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated (anonymously or otherwise)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow read/write to the users collection for authenticated users
    // In a real production app, this should be restricted to the specific user's document
    // and admin users. For this prototype with custom phone/password auth, we allow access.
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }
  }
}
